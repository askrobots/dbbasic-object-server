{
  "name": "articles",
  "title": "Articles",
  "version": 3,
  "description": "Long-form writing. Schema versions and record changelogs provide edit history. v3 adds blocks.feed (64 - Feed), opting articles into the follow-graph feed as its worked-example feed source; purely additive metadata, no field/behavior change.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "title",
      "type": "text",
      "required": true,
      "label": "Title",
      "validation": {"min_length": 1, "max_length": 200}
    },
    {
      "name": "content",
      "type": "textarea",
      "required": true,
      "label": "Content",
      "validation": {"min_length": 1}
    },
    {
      "name": "is_public",
      "type": "boolean",
      "label": "Published",
      "default": "false",
      "help": "Published articles are readable by anyone at their permalink"
    },
    {
      "name": "published_on",
      "type": "date",
      "label": "Published On"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "label": "Created",
      "read_only": true
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["title", "content", "is_public", "published_on"]}
  },
  "views": {
    "list_mode": "feed",
    "list_fields": ["title", "published_on", "is_public"]
  },
  "search": {
    "fields": ["title", "content"],
    "result_fields": ["id", "title", "published_on", "is_public"]
  },
  "blocks": {
    "feed": {
      "owner_field": "owner_id",
      "visibility_field": "is_public",
      "visibility_true_value": "true",
      "time_field": "published_on",
      "summary_fields": ["title"],
      "link_field": "id"
    }
  }
}
