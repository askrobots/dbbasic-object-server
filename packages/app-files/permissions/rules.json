{
  "rules": [
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "files",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage their own files"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": ["read"],
      "collection": "files",
      "row_filter": {"is_public": "true"},
      "reason": "files marked public are downloadable by anyone"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["read"],
      "collection": "files",
      "row_filter": {"project_id": "$accessible_projects"},
      "reason": "files in projects shared with a user are readable"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": ["execute"],
      "object_id": "site_files",
      "reason": "the files page is public; it shows a sign-in prompt to visitors"
    }
  ]
}
