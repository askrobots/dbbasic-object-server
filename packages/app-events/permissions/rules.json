{
  "rules": [
    {
      "effect": "allow",
      "principal": "registered",
      "actions": [
        "create",
        "read",
        "update",
        "delete"
      ],
      "collection": "events",
      "row_filter": {
        "owner_id": "$user_id"
      },
      "reason": "signed-in users manage their own events"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": [
        "read"
      ],
      "collection": "events",
      "row_filter": {
        "project_id": "$accessible_projects"
      },
      "reason": "events in projects shared with a user are readable"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": [
        "execute"
      ],
      "object_id": "site_calendar",
      "reason": "the calendar page is public; it shows a sign-in prompt to visitors"
    }
  ]
}