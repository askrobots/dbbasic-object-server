{
  "name": "templates",
  "title": "Templates",
  "version": 1,
  "description": "Reusable template bodies. Edit history comes from the record changelog.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "name",
      "type": "text",
      "required": true,
      "label": "Name",
      "validation": {"min_length": 1, "max_length": 120}
    },
    {
      "name": "description",
      "type": "text",
      "label": "Description",
      "validation": {"max_length": 300}
    },
    {
      "name": "category",
      "type": "text",
      "label": "Category"
    },
    {
      "name": "body",
      "type": "textarea",
      "required": true,
      "label": "Body",
      "validation": {"min_length": 1}
    },
    {
      "name": "tags",
      "type": "text",
      "label": "Tags",
      "help": "Comma-separated tag names"
    },
    {
      "name": "is_public",
      "type": "boolean",
      "label": "Public",
      "default": "false"
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["name", "description", "category", "body", "tags", "is_public"]}
  },
  "views": {
    "list_mode": "table",
    "list_fields": ["name", "category", "is_public"]
  },
  "search": {
    "fields": ["name", "description", "body", "tags"]
  }
}
