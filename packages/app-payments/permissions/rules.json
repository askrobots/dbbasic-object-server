{
  "rules": [
    {"effect": "allow", "principal": "registered",
     "actions": ["create", "read", "update", "delete"],
     "collection": "payments", "row_filter": {"owner_id": "$user_id"},
     "reason": "signed-in users manage payments they recorded"},
    {"effect": "allow", "principal": "registered",
     "actions": ["create", "read", "update", "delete"],
     "collection": "refunds", "row_filter": {"owner_id": "$user_id"},
     "reason": "signed-in users manage refunds they recorded"},
    {"effect": "allow", "principal": "public", "actions": ["execute"],
     "object_id": "site_payments",
     "reason": "the payments page is a public static shell; data stays row-gated"}
  ]
}
