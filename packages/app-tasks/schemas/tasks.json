{
  "name": "tasks",
  "title": "Tasks",
  "version": 5,
  "description": "Work items with an enforced status lifecycle. Transition guards add who-per-verb on top of row-filtered update rights.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "title",
      "type": "text",
      "required": true,
      "label": "Title",
      "validation": {"min_length": 1, "max_length": 200}
    },
    {
      "name": "description",
      "type": "textarea",
      "label": "Description"
    },
    {
      "name": "project_id",
      "label": "Project",
      "relation": {"collection": "projects", "display_field": "name"}
    },
    {
      "name": "status",
      "type": "enum",
      "label": "Status",
      "default": "open",
      "enum": ["draft", "open", "assigned", "waiting_on_client", "approved", "disputed", "cancelled"],
      "transitions": {
        "draft": [
          {"to": "open", "when": {"owner_id": "$user_id"}},
          {"to": "assigned", "when": {"owner_id": "$user_id"}},
          {"to": "cancelled", "when": {"owner_id": "$user_id"}}
        ],
        "open": [
          "assigned",
          {"to": "cancelled", "when": {"owner_id": "$user_id"}}
        ],
        "assigned": [
          {"to": "waiting_on_client", "when": {"assigned_to": "$user_id"}},
          {"to": "open", "when": {"assigned_to": "$user_id"}},
          {"to": "cancelled", "when": {"owner_id": "$user_id"}}
        ],
        "waiting_on_client": [
          {"to": "approved", "when": {"owner_id": "$user_id"}},
          {"to": "disputed", "when": {"owner_id": "$user_id"}},
          "assigned"
        ],
        "disputed": [
          {"to": "assigned", "when": {"owner_id": "$user_id"}},
          {"to": "cancelled", "when": {"owner_id": "$user_id"}}
        ]
      },
      "help": "approved and cancelled are terminal. draft moves and cancelling require the task owner; returning or submitting an assigned task requires the current assignee; resolving waiting_on_client or a dispute requires the owner. Anyone with update rights may accept an open task."
    },
    {
      "name": "urgency",
      "type": "enum",
      "label": "Urgency",
      "default": "normal",
      "enum": ["low", "normal", "high", "critical"]
    },
    {
      "name": "due_date",
      "type": "date",
      "label": "Due Date"
    },
    {
      "name": "assigned_to",
      "type": "text",
      "label": "Assigned To",
      "help": "User id of the worker"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "label": "Created",
      "read_only": true
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["title", "description", "project_id", "status",
                           "urgency", "due_date", "assigned_to"]}
  },
  "views": {
    "list_mode": "table",
    "list_fields": ["title", "status", "urgency", "due_date", "assigned_to"]
  },
  "search": {
    "fields": ["title", "description"]
  }
}
