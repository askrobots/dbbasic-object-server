{
  "name": "tasks",
  "title": "Tasks",
  "version": 2,
  "description": "Work items with an enforced status lifecycle.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "title",
      "type": "text",
      "required": true,
      "label": "Title",
      "validation": {"min_length": 1, "max_length": 200}
    },
    {
      "name": "description",
      "type": "textarea",
      "label": "Description"
    },
    {
      "name": "project_id",
      "label": "Project",
      "relation": {"collection": "projects", "display_field": "name"}
    },
    {
      "name": "status",
      "type": "enum",
      "label": "Status",
      "default": "open",
      "enum": ["open", "assigned", "waiting_on_client", "approved", "disputed", "cancelled"],
      "transitions": {
        "open": ["assigned", "cancelled"],
        "assigned": ["waiting_on_client", "open", "cancelled"],
        "waiting_on_client": ["approved", "disputed", "assigned"],
        "disputed": ["assigned", "cancelled"]
      },
      "help": "approved and cancelled are terminal"
    },
    {
      "name": "urgency",
      "type": "enum",
      "label": "Urgency",
      "default": "normal",
      "enum": ["low", "normal", "high", "critical"]
    },
    {
      "name": "due_date",
      "type": "date",
      "label": "Due Date"
    },
    {
      "name": "assigned_to",
      "type": "text",
      "label": "Assigned To",
      "help": "User id of the worker"
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["title", "description", "project_id", "status",
                           "urgency", "due_date", "assigned_to"]}
  },
  "views": {
    "list_mode": "table",
    "list_fields": ["title", "status", "urgency", "due_date", "assigned_to"]
  },
  "search": {
    "fields": ["title", "description"]
  }
}
