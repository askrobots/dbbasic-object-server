{
  "rules": [
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "notes",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage their own notes"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": ["read"],
      "collection": "notes",
      "row_filter": {"is_public": "true"},
      "reason": "notes marked public are readable by anyone"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["read"],
      "collection": "notes",
      "row_filter": {"project_id": "$accessible_projects"},
      "reason": "notes in projects shared with a user are readable"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": ["execute"],
      "object_id": "site_notes",
      "reason": "the notes page is public; it shows a sign-in prompt to visitors"
    }
  ]
}
