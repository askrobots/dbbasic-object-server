{
  "id": "app-notes",
  "name": "Notes",
  "version": "0.2.0",
  "description": "Quick notes: owner-scoped with public sharing, project links, permalinks, and global search. Permalinks need a site_routes record mapping /notes/{note_id:uuid} to site_note_view.",
  "compatibility": {
    "dbbasic_object_server": ">=0.1.0"
  },
  "dependencies": ["app-projects"],
  "objects": [
    {
      "id": "site_notes",
      "path": "objects/site/notes.py"
    },
    {
      "id": "site_note_view",
      "path": "objects/site/note_view.py"
    }
  ],
  "schemas": [
    {
      "collection": "notes",
      "path": "schemas/notes.json"
    }
  ],
  "permissions": [
    {
      "path": "permissions/rules.json"
    }
  ],
  "seed": [
    {
      "collection": "notes",
      "path": "seed/notes.tsv"
    }
  ],
  "migrations": []
}
