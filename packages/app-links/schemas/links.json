{
  "name": "links",
  "title": "Links",
  "version": 1,
  "description": "Saved links and bookmarks.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "title",
      "type": "text",
      "required": true,
      "label": "Title",
      "validation": {"min_length": 1, "max_length": 200}
    },
    {
      "name": "url",
      "type": "text",
      "required": true,
      "label": "URL",
      "validation": {"min_length": 1, "max_length": 2000, "pattern": "^https?://"}
    },
    {
      "name": "tags",
      "type": "text",
      "label": "Tags",
      "help": "Comma-separated tag names"
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["title", "url", "tags"]}
  },
  "views": {
    "list_mode": "table",
    "list_fields": ["title", "url", "tags"]
  },
  "search": {
    "fields": ["title", "url", "tags"]
  }
}
