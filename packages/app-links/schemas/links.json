{
  "name": "links",
  "title": "Links",
  "version": 2,
  "description": "Saved links and bookmarks.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "title",
      "type": "text",
      "required": true,
      "label": "Title",
      "validation": {"min_length": 1, "max_length": 200}
    },
    {
      "name": "url",
      "type": "text",
      "required": true,
      "label": "URL",
      "placeholder": "https://",
      "validation": {"min_length": 1, "max_length": 2000, "pattern": "^https?://\\S+$"}
    },
    {
      "name": "description",
      "type": "textarea",
      "label": "Description"
    },
    {
      "name": "tags",
      "type": "text",
      "label": "Tags",
      "help": "Separate tags with commas (e.g. reference, docs, tutorial)"
    },
    {
      "name": "notes",
      "type": "textarea",
      "label": "Notes"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "label": "Added",
      "read_only": true
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["title", "url", "description", "tags", "notes"]}
  },
  "views": {
    "list_mode": "cards",
    "list_fields": ["title", "url", "tags"]
  },
  "search": {
    "fields": ["title", "url", "description", "tags", "notes"]
  }
}
