{
  "rules": [
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "user_prefs",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage their own preferences"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["read"],
      "collection": "feature_flags",
      "reason": "signed-in users can read feature flags"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["read"],
      "collection": "ai_prices",
      "reason": "signed-in users can read AI pricing (e.g. to show estimated cost before sending a chat); only admins can edit prices"
    }
  ]
}
