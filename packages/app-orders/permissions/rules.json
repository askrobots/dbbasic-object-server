{
  "rules": [
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "orders",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage sales and purchase orders they created"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "order_lines",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage line items on orders they created"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": ["execute"],
      "object_id": "site_orders",
      "reason": "the orders page is public; it shows a sign-in prompt to visitors"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": ["execute"],
      "object_id": "site_order_view",
      "reason": "the order detail page is public; the row-filtered collection API still decides which order is actually returned"
    }
  ]
}
