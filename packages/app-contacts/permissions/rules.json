{
  "rules": [
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "contacts",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage their own contacts"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["read"],
      "collection": "contacts",
      "row_filter": {"project_id": "$accessible_projects"},
      "reason": "contacts in projects shared with a user are readable"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "organizations",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage their own organizations"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "interactions",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage their own interaction log"
    },
    {
      "effect": "allow",
      "principal": "registered",
      "actions": ["create", "read", "update", "delete"],
      "collection": "tags",
      "row_filter": {"owner_id": "$user_id"},
      "reason": "signed-in users manage their own tags"
    },
    {
      "effect": "allow",
      "principal": "public",
      "actions": ["execute"],
      "object_id": "site_contacts",
      "reason": "the contacts page is public; it shows a sign-in prompt to visitors"
    }
  ]
}
