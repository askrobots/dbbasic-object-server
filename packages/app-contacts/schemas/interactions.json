{
  "name": "interactions",
  "title": "Interactions",
  "version": 2,
  "description": "Calls, emails, meetings, notes, and tasks logged against a contact.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "contact_id",
      "required": true,
      "label": "Contact",
      "relation": {"collection": "contacts", "display_field": "first_name"}
    },
    {
      "name": "kind",
      "type": "enum",
      "label": "Kind",
      "default": "note",
      "enum": ["call", "email", "meeting", "note", "task"]
    },
    {
      "name": "subject",
      "type": "text",
      "label": "Subject",
      "validation": {"max_length": 200}
    },
    {
      "name": "occurred_on",
      "type": "date",
      "label": "Date"
    },
    {
      "name": "duration_minutes",
      "type": "integer",
      "label": "Duration (minutes)"
    },
    {
      "name": "outcome",
      "type": "enum",
      "label": "Outcome",
      "enum": ["positive", "neutral", "negative", "no_answer"],
      "help": "Optional; blank until set, no default is forced"
    },
    {
      "name": "summary",
      "type": "textarea",
      "required": true,
      "label": "Summary",
      "validation": {"min_length": 1}
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["contact_id", "kind", "subject", "occurred_on",
                           "duration_minutes", "outcome", "summary"]}
  },
  "views": {
    "list_mode": "feed",
    "list_fields": ["contact_id", "kind", "subject", "occurred_on", "summary"]
  },
  "search": {
    "fields": ["summary"]
  }
}
