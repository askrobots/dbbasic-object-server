{
  "name": "contacts",
  "title": "Contacts",
  "version": 6,
  "description": "People: the core CRM record.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "first_name",
      "type": "text",
      "required": true,
      "label": "First Name",
      "validation": {
        "min_length": 1,
        "max_length": 80
      }
    },
    {
      "name": "last_name",
      "type": "text",
      "label": "Last Name",
      "validation": {
        "max_length": 80
      }
    },
    {
      "name": "full_name",
      "type": "computed",
      "label": "Name",
      "formula": "first_name + \" \" + last_name"
    },
    {
      "name": "email",
      "type": "text",
      "label": "Email",
      "validation": {
        "max_length": 254
      }
    },
    {
      "name": "phone",
      "type": "text",
      "label": "Phone",
      "validation": {
        "max_length": 40
      }
    },
    {
      "name": "job_title",
      "type": "text",
      "label": "Job Title",
      "validation": {
        "max_length": 120
      }
    },
    {
      "name": "organization_id",
      "label": "Organization",
      "relation": {
        "collection": "organizations",
        "display_field": "name"
      }
    },
    {
      "name": "project_id",
      "label": "Project",
      "relation": {
        "collection": "projects",
        "display_field": "name"
      }
    },
    {
      "name": "lead_status",
      "type": "enum",
      "label": "Lead Status",
      "enum": [
        "cold",
        "warm",
        "hot",
        "customer",
        "inactive"
      ],
      "help": "Optional pipeline stage; blank until set, no default is forced",
      "transitions": {
        "cold": [
          "warm",
          "hot",
          "customer",
          "inactive"
        ],
        "warm": [
          "cold",
          "hot",
          "customer",
          "inactive"
        ],
        "hot": [
          "cold",
          "warm",
          "customer",
          "inactive"
        ],
        "customer": [
          "cold",
          "warm",
          "hot",
          "inactive"
        ],
        "inactive": [
          "cold",
          "warm",
          "hot",
          "customer"
        ]
      }
    },
    {
      "name": "tags",
      "type": "text",
      "label": "Tags",
      "help": "Comma-separated tag names"
    },
    {
      "name": "notes",
      "type": "textarea",
      "label": "Notes"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "label": "Created",
      "read_only": true
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {
      "fields": [
        "first_name",
        "last_name",
        "email",
        "phone",
        "job_title",
        "organization_id",
        "project_id",
        "lead_status",
        "tags",
        "notes"
      ]
    }
  },
  "views": {
    "list_mode": "board",
    "list_fields": [
      "first_name",
      "last_name",
      "email",
      "organization_id",
      "lead_status"
    ],
    "detail_fields": [
      "first_name",
      "last_name",
      "email",
      "phone",
      "job_title",
      "organization_id",
      "project_id",
      "lead_status",
      "tags",
      "notes"
    ],
    "related": [
      {
        "collection": "interactions",
        "fk_field": "contact_id"
      }
    ],
    "filter_fields": [
      "lead_status"
    ]
  },
  "search": {
    "fields": [
      "first_name",
      "last_name",
      "email",
      "tags",
      "notes"
    ]
  }
}
