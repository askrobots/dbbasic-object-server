{
  "name": "contacts",
  "title": "Contacts",
  "version": 2,
  "description": "People: the core CRM record.",
  "fields": [
    {
      "name": "id"
    },
    {
      "name": "first_name",
      "type": "text",
      "required": true,
      "label": "First Name",
      "validation": {"min_length": 1, "max_length": 80}
    },
    {
      "name": "last_name",
      "type": "text",
      "label": "Last Name",
      "validation": {"max_length": 80}
    },
    {
      "name": "email",
      "type": "text",
      "label": "Email",
      "validation": {"max_length": 254}
    },
    {
      "name": "phone",
      "type": "text",
      "label": "Phone",
      "validation": {"max_length": 40}
    },
    {
      "name": "organization_id",
      "label": "Organization",
      "relation": {"collection": "organizations", "display_field": "name"}
    },
    {
      "name": "project_id",
      "label": "Project",
      "relation": {"collection": "projects", "display_field": "name"}
    },
    {
      "name": "tags",
      "type": "text",
      "label": "Tags",
      "help": "Comma-separated tag names"
    },
    {
      "name": "notes",
      "type": "textarea",
      "label": "Notes"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "label": "Created",
      "read_only": true
    },
    {
      "name": "owner_id",
      "type": "text",
      "label": "Owner"
    }
  ],
  "forms": {
    "default": {"fields": ["first_name", "last_name", "email", "phone",
                           "organization_id", "project_id", "tags", "notes"]}
  },
  "views": {
    "list_mode": "cards",
    "list_fields": ["first_name", "last_name", "email", "organization_id"]
  },
  "search": {
    "fields": ["first_name", "last_name", "email", "tags", "notes"]
  }
}
